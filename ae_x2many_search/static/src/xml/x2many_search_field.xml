<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ae_x2many_search.ListRenderer.Rows">
        <t t-if="!list.isGrouped">
            <t t-set="lastGroupKey" t-value="undefined"/>
            <t t-foreach="list.records" t-as="record" t-key="record.id">
                <t t-if="props.groupField and this.getGroupValue(record) !== lastGroupKey">
                    <tr class="o_x2m_group_header_row" t-att-data-group-key="this.getGroupValue(record)" t-on-click="(ev) => this.onToggleGroup(ev.currentTarget.dataset.groupKey)">
                        <td t-att-colspan="nbCols" class="o_x2m_group_header_cell">
                            <i t-att-class="'fa me-2 ' + (this.isGroupCollapsed(this.getGroupValue(record)) ? 'fa-caret-right' : 'fa-caret-down')"/>
                            <span class="o_x2m_group_header_label"><t t-esc="this.getGroupValue(record)"/></span>
                            <span class="o_x2m_group_header_count"><t t-esc="this.getGroupCount(this.getGroupValue(record))"/></span>
                        </td>
                    </tr>
                    <t t-set="lastGroupKey" t-value="this.getGroupValue(record)"/>
                </t>
                <t t-if="!props.groupField or !this.isGroupCollapsed(this.getGroupValue(record))">
                    <t t-call="{{ constructor.recordRowTemplate }}"/>
                </t>
            </t>
            <tr t-if="displayRowCreates">
                <td t-if="withHandleColumn"/>
                <td t-att-colspan="withHandleColumn ? nbCols - 1 : nbCols"
                    class="o_field_x2many_list_row_add"
                    t-on-keydown="(ev) => this.onCellKeydown(ev, null)"
                >
                    <t t-foreach="creates" t-as="create" t-key="create_index">
                        <a
                            t-if="create.type === 'create'"
                            href="#"
                            role="button"
                            t-att-class="create_index !== 0 ? 'ml16' : ''"
                            t-att-tabindex="editedRecord ? '-1' : '0'"
                            t-on-click.stop.prevent="() => this.add({ context: create.context })"
                        >
                            <t t-esc="create.string"/>
                        </a>
                        <ViewButton
                            t-if="create.type === 'button'"
                            className="`${create.className} ${create_index !== 0 ? 'ml16' : ''}`"
                            clickParams="create.clickParams"
                            icon="create.icon"
                            record="props.list"
                            string="create.string"
                            title="create.title"
                            tabindex="editedRecord ? '-1' : '0'"
                        />
                    </t>
                </td>
            </tr>
            <t t-if="!props.list.isGrouped">
                <tr t-foreach="getEmptyRowIds" t-as="emptyRowId" t-key="emptyRowId">
                    <td t-att-colspan="nbCols">&#8203;</td>
                </tr>
            </t>
        </t>
        <t t-else="">
            <t t-foreach="list.groups" t-as="group" t-key="group.id">
                <t t-call="{{ constructor.groupRowTemplate }}"/>
            </t>
        </t>
    </t>

    <t t-name="ae_x2many_search.X2ManySearchField">
        <div t-att-class="className + ' o_x2m_search_widget'">
            <div class="o_x2m_control_panel o_x2m_search_control_panel d-empty-none">

                <div class="o_x2m_searchview_wrap d-flex input-group" t-ref="searchWrapper">

                    <div class="o_x2m_searchview form-control d-flex align-items-center py-1 gap-1">
                        <i class="o_searchview_icon oi oi-search me-1 text-muted" aria-hidden="true"/>
                        <div class="o_x2m_searchview_input_container d-flex flex-grow-1 align-items-center gap-1 overflow-hidden">

                            <t t-foreach="facetOrder.order" t-as="facetType" t-key="facetType">
                                <t t-if="facetType === 'filter' and searchState.activeFilter">
                                    <div class="o_searchview_facet d-inline-flex align-items-stretch rounded-2 bg-200 text-nowrap flex-shrink-0">
                                        <div class="o_searchview_facet_label rounded-start-2 px-1 text-bg-primary d-flex align-items-center">
                                            <t t-if="searchState.activeFilter.fieldLabel">
                                                <small class="px-1"><t t-esc="searchState.activeFilter.fieldLabel"/></small>
                                            </t>
                                        </div>
                                        <div class="o_facet_values d-flex align-items-center ps-2 rounded-end-2">
                                            <small class="o_facet_value"><t t-esc="searchState.activeFilter.query"/></small>
                                            <button class="o_facet_remove oi oi-close btn btn-link py-0 px-2 text-danger"
                                                type="button"
                                                aria-label="Remove"
                                                t-on-mousedown.prevent="onClearFilter"
                                            />
                                        </div>
                                    </div>
                                </t>
                                <t t-if="facetType === 'group' and groupState.activeField">
                                    <div class="o_searchview_facet d-inline-flex align-items-stretch rounded-2 bg-200 text-nowrap flex-shrink-0">
                                        <div class="o_searchview_facet_label rounded-start-2 px-1 text-bg-action d-flex align-items-center">
                                            <i class="small fa-fw oi oi-group" role="image"/>
                                        </div>
                                        <div class="o_facet_values d-flex align-items-center ps-2 rounded-end-2">
                                            <small class="o_facet_value"><t t-esc="activeGroupLabel"/></small>
                                            <button class="o_facet_remove oi oi-close btn btn-link py-0 px-2 text-danger"
                                                type="button"
                                                aria-label="Remove"
                                                t-on-mousedown.prevent="onClearGroupBy"
                                            />
                                        </div>
                                    </div>
                                </t>
                            </t>

                            <input
                                type="text"
                                class="o_x2m_search_input o_input flex-grow-1 w-auto border-0"
                                placeholder="Search..."
                                t-att-value="searchState.inputValue"
                                t-on-input="onSearchInput"
                                t-on-focus="onSearchFocus"
                                t-on-keydown="onSearchKeydown"
                                autocomplete="off"
                            />
                        </div>

                        <t t-if="searchState.showDropdown">
                            <ul class="o-dropdown--menu dropdown-menu o_x2m_search_autocomplete show">
                                <t t-foreach="dropdownSuggestions" t-as="suggestion" t-key="suggestion.fieldName">
                                    <li class="o_menu_item dropdown-item"
                                        t-att-class="searchState.focusedIndex === suggestion_index ? 'focus' : ''"
                                        t-on-mousedown.prevent="() => this.onSelectField(suggestion.fieldName)"
                                    >
                                        <a href="#" t-on-click.prevent="">
                                            Search <b t-esc="suggestion.label"/>
                                        </a>
                                    </li>
                                </t>
                            </ul>
                        </t>
                    </div>

                    <div class="o_x2m_groupby_wrapper" t-ref="groupWrapper">
                        <button
                            type="button"
                            class="o_x2m_groupby_toggler btn btn-outline-secondary rounded-start-0 h-100 o-no-caret"
                            t-on-click="onToggleGroupDropdown"
                        >
                            <i class="fa fa-caret-down" aria-hidden="true"/>
                        </button>

                        <div t-if="groupState.showDropdown" class="o_x2m_groupby_dropdown_menu">
                            <div class="o_dropdown_container px-3 py-2">
                                <div class="px-1 mb-2">
                                    <i class="me-2 text-action oi oi-group"/>
                                    <h6 class="o_dropdown_title d-inline mb-0">Group By</h6>
                                </div>
                                <t t-foreach="groupByFields" t-as="field" t-key="field.fieldName">
                                    <div
                                        class="o_menu_item dropdown-item rounded-2 d-flex align-items-center gap-2"
                                        t-att-class="groupState.activeField === field.fieldName ? 'o_x2m_groupby_active' : ''"
                                        t-on-mousedown.prevent="() => this.onSelectGroupBy(field.fieldName)"
                                    >
                                        <i t-att-class="groupState.activeField === field.fieldName ? 'fa fa-check fa-fw' : 'fa fa-fw'"/>
                                        <span t-esc="field.label"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <t t-if="displayControlPanelButtons">
                    <div class="o_cp_buttons gap-1" role="toolbar" aria-label="Control panel buttons" t-ref="buttons">
                        <t t-foreach="creates" t-as="create" t-key="create_index">
                            <button
                                t-if="create.type === 'create'"
                                type="button"
                                class="btn btn-secondary"
                                t-att-class="create.class"
                                t-on-click.stop.prevent="() => this.onAdd({ context: create.context })"
                            >
                                <t t-esc="create.string"/>
                            </button>
                            <ViewButton
                                t-if="create.type === 'button'"
                                className="`${create.className}`"
                                clickParams="create.clickParams"
                                icon="create.icon"
                                record="props.record.data[props.name]"
                                string="create.string"
                                title="create.title"
                            />
                        </t>
                    </div>
                </t>

                <div t-if="props.record.data[props.name].count > props.record.data[props.name].limit" class="o_cp_pager" role="search">
                    <Pager t-props="pagerProps"/>
                </div>
            </div>

            <ListRenderer t-if="props.viewMode === 'list'" t-props="this.rendererProps"/>
            <KanbanRenderer t-elif="props.viewMode" t-props="this.rendererProps"/>
        </div>
    </t>

</templates>
