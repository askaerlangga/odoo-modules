<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_report_form_inherit_domain" model="ir.ui.view">
        <field name="name">ir.actions.report.form.inherit.domain</field>
        <field name="model">ir.actions.report</field>
        <field name="inherit_id" ref="base.act_report_xml_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='print_report_name']" position="after">
                <field name="domain"
                       placeholder="e.g. [('state', '=', 'posted')]"
                       help="If set, this report will only appear in the Print menu when at least one selected record matches this domain."/>
            </xpath>
        </field>
    </record>
</odoo>
